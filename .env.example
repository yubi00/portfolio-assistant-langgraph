# Required for real LLM-backed classification and answer generation.
OPENAI_API_KEY=

# Phase 1 uses one general model for classification, context resolution, and answer generation.
OPENAI_MODEL_DEFAULT=gpt-4.1-mini
OPENAI_TEMPERATURE=0.2

# Keep this generic so the same app can serve any portfolio owner.
ASSISTANT_SUBJECT=the portfolio owner
ASSISTANT_DISPLAY_NAME=Portfolio Assistant

# GitHub project retrieval.
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_PROJECTS_LIMIT=12
GITHUB_INCLUDE_FORKS=false

# Local text/markdown retrieval. PDF/DOCX ingestion will be added later.
DOCS_PATH=
MERGED_CONTEXT_MAX_CHARS=12000

# Local observability.
LOG_LEVEL=INFO
LOG_COLOR=true
