# Required for real LLM-backed classification and answer generation.
OPENAI_API_KEY=

# Phase 1 uses one general model for classification, context resolution, and answer generation.
OPENAI_MODEL_DEFAULT=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TEMPERATURE=0.2
OPENAI_TIMEOUT_SECONDS=30
OPENAI_MAX_RETRIES=2

# Required portfolio subject for this deployment.
ASSISTANT_SUBJECT=

# GitHub project retrieval.
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_PROJECTS_LIMIT=12
GITHUB_INCLUDE_FORKS=false
GITHUB_README_MAX_CHARS=1800
GITHUB_TARGET_README_MAX_CHARS=6000
FEATURED_PROJECTS_PATH=portfolio/featured_projects.json

# Docs retrieval. Place the resume at data/resume.md or data/resume.pdf.
DOCS_PATH=
MERGED_CONTEXT_MAX_CHARS=12000

# Offline resume vector indexing. Required when running `portfolio-index-resume`.
NEON_DATABASE_URL_STRING=
RESUME_VECTOR_NAMESPACE=default
RESUME_CHUNK_MAX_CHARS=1200
RESUME_VECTOR_TOP_K=5

# Public API abuse protection.
RATE_LIMIT_ENABLED=true
PROMPT_RATE_LIMIT=30/minute
PROMPT_STREAM_RATE_LIMIT=10/minute
MAX_ACTIVE_STREAMS_PER_CLIENT=2

# Local observability.
LOG_LEVEL=INFO
LOG_COLOR=true
LOG_FORMAT=text
